  // Recording
  // toggleRecord 改为启动/结束 Gemini Live 对话
  async function toggleRecord() {
    if (convActive) {
      endConversation();
    } else {
      await startConversation();
    }
  }

  // ===== Gemini Live 对话函数 =====

  async function startConversation() {
    if (convActive) return;
    convActive = true;
    partialEls = {};
    document.getElementById('convArea').innerHTML = '';
    document.getElementById('convArea').classList.add('active');
    document.getElementById('endConvBtn').classList.add('active');
    document.getElementById('recordBtn').classList.add('recording');
    document.getElementById('recordHint').textContent = t('connecting');
    document.getElementById('recordBtn').disabled = true;

    // iOS 媒体声道解锁（让硬件音量键生效）
    try {
      const _sil = document.createElement('audio');
      _sil.src = 'data:audio/wav;base64,UklGRigAAABXQVZFZm10IBIAAAABAAEARKwAAIhYAQACABAAAABkYXRhAgAAAAEA';
      _sil.setAttribute('playsinline', '');
      await _sil.play();
    } catch(e) {}

    // 15s 连接超时：若未收到 ready 则自动重置
    connectTimer = setTimeout(() => {
      if (convActive && !captureCtx) {
        showToast(t('connFail'));
        resetConvUI();
      }
    }, 15000);

    liveWs = new WebSocket(WS_URL);
    liveWs.onopen = () => {
      const todayStr = getTodayStr();
      const todayTime = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
      const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const recentEntries = entries
        .filter(e => !e.hidden && !e.loading)
        .sort((a, b) => b.id - a.id)
        .slice(0, 8)
        .map(e => ({ date: e.date, time: e.time, text: e.text.substring(0, 200) }));
      const todaySummary = summaries[todayStr] || null;
      liveWs.send(JSON.stringify({
        type: 'start',
        lang: currentLang,
        context: { today: todayStr, todayTime, timezone, recentEntries, todaySummary }
      }));
    };
    liveWs.onmessage = handleLiveMessage;
    liveWs.onerror = () => { showToast(t('connFail')); resetConvUI(); };
    liveWs.onclose = () => { if (convActive) resetConvUI(); };
  }

  async function handleLiveMessage(event) {
    const msg = JSON.parse(event.data);

    if (msg.type === 'ready') {
      clearTimeout(connectTimer); connectTimer = null;
      // 开始麦克风采集（PCM 16kHz）
      try {
        micStream = await navigator.mediaDevices.getUserMedia({
          audio: { sampleRate: 16000, channelCount: 1, echoCancellation: true, noiseSuppression: true }
        });
        captureCtx = new AudioContext({ sampleRate: 16000 });
        const blobUrl = URL.createObjectURL(
          new Blob([WORKLET_CODE], { type: 'application/javascript' })
        );
        await captureCtx.audioWorklet.addModule(blobUrl);
        URL.revokeObjectURL(blobUrl);

        const source = captureCtx.createMediaStreamSource(micStream);
        workletNode = new AudioWorkletNode(captureCtx, 'pcm-proc');
        workletNode.port.onmessage = (e) => {
          if (liveWs?.readyState !== 1) return;
          // 客户端 VAD：连续 N 帧超过阈值才打断（防回声/噪音误触）
          if (modelSpeaking && !userBargedIn) {
            const samples = new Int16Array(e.data);
            let sum = 0;
            for (let i = 0; i < samples.length; i++) sum += samples[i] * samples[i];
            if (Math.sqrt(sum / samples.length) > VAD_THRESHOLD) {
              if (++vadFrameCount >= VAD_FRAMES_REQUIRED) {
                stopPlayback();
                modelSpeaking = false;
                userBargedIn = true;
                vadFrameCount = 0;
                // 安全超时：若模型 15s 内未完成轮次则自动解除打断锁
                clearTimeout(bargeInTimer);
                bargeInTimer = setTimeout(() => { userBargedIn = false; bargeInTimer = null; }, 15000);
              }
            } else {
              vadFrameCount = 0;
            }
          }
          // model 说话时不向 Gemini 发送麦克风音频（防止回声被 Gemini 误识别为用户语音，导致模型提前截断）
          if (modelSpeaking) return;
          const b64 = btoa(String.fromCharCode(...new Uint8Array(e.data)));
          liveWs.send(JSON.stringify({ type: 'audio', data: b64 }));
          // 首次发送时启动超时计时器（必须等念念完成首次回复后才启动，防止截断问候语）
          if (!audioSendStart && !modelSpeaking && modelHasSpoken) {
            audioSendStart = Date.now();
            forceEndTimer = setTimeout(() => {
              if (liveWs?.readyState === 1) {
                liveWs.send(JSON.stringify({ type: 'forceEndTurn' }));
              }
              audioSendStart = null;
              forceEndTimer = null;
            }, 15000);
          }
        };
        source.connect(workletNode);

        document.getElementById('recordBtn').disabled = false;
        document.getElementById('recordHint').textContent = t('greeting');
      } catch (e) {
        showToast(t('micFail'));
        endConversation();
      }

    } else if (msg.type === 'audio') {
      if (userBargedIn) return;  // 用户已打断，忽略剩余模型音频
      vadFrameCount = 0;  // 模型开始新音频，重置帧计数器
      // 播放 Gemini 语音（PCM 24kHz）
      playPCMChunk(msg.data, 24000);
      // 收集念念语音 PCM 数据，供对话结束后保存
      { const bin = atob(msg.data); const raw = new Int16Array(bin.length / 2);
        for (let i = 0; i < raw.length; i++) raw[i] = (bin.charCodeAt(i*2) | (bin.charCodeAt(i*2+1) << 8));
        convModelPCM.push(raw); }
      document.getElementById('speakWave').classList.add('active');
      // 模型开始回应：确认待定的用户气泡（turn-user 可能还未到达）
      if (partialEls['user']) {
        partialEls['user'].bubble.classList.remove('partial');
        partialEls['user'] = null;
      }
      modelSpeaking = true;
      clearTimeout(forceEndTimer); forceEndTimer = null; audioSendStart = null;

    } else if (msg.type === 'partial') {
      // 用户开口打断：立即停止 agent 播放
      if (msg.role === 'user' && modelSpeaking) {
        stopPlayback();
        modelSpeaking = false;
        userBargedIn = true;
        clearTimeout(bargeInTimer);
        bargeInTimer = setTimeout(() => { userBargedIn = false; bargeInTimer = null; }, 15000);
      }
      // 用户开口时重置模型气泡合并状态
      if (msg.role === 'user') {
        lastModelBubble = null;
        lastModelTextPrefix = '';
      }
      updatePartialBubble(msg.role, msg.text);
      // 模型开始转录，重置计时器
      if (msg.role === 'model') {
        clearTimeout(forceEndTimer); forceEndTimer = null; audioSendStart = null;
      }

    } else if (msg.type === 'turn') {
      finalizeBubble(msg.role, msg.text);
      if (msg.role === 'user') {
        // VAD 已触发，用户轮次完成 → 停止 forceEnd 计时器（等模型自然回应）
        clearTimeout(forceEndTimer); forceEndTimer = null; audioSendStart = null;
        // 用户说完话，重置模型气泡合并状态（下一段模型回复是全新气泡）
        lastModelBubble = null;
        lastModelTextPrefix = '';
      }
      if (msg.role === 'model') {
        modelSpeaking = false;
        userBargedIn = false;
        clearTimeout(bargeInTimer); bargeInTimer = null;
        modelHasSpoken = true;  // 念念完成首次回复，此后允许启动 forceEnd 计时器
        document.getElementById('speakWave').classList.remove('active');
        // 念念说完第一句后，提示用户可以开口
        const hint = document.getElementById('recordHint');
        if (hint.textContent === t('greeting')) {
          hint.textContent = t('convActive');
        }
      }

    } else if (msg.type === 'save_note') {
      const id = Date.now();
      const timeStr = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
      entries.push({ id, date: getTodayStr(), time: timeStr, text: '📌 ' + msg.text, loading: false });
      saveEntries();
      renderEntries();
      showToast(t('noteToast'));

    } else if (msg.type === 'done') {
      finishConversation(msg.transcript);

    } else if (msg.type === 'error') {
      showToast(t('convErr') + (msg.message || '未知错误'));
      resetConvUI();
    }
  }

  function addSystemBubble(text) {
    const area = document.getElementById('convArea');
    const el = document.createElement('div');
    el.style.cssText = 'text-align:center;font-size:0.72rem;color:var(--text-dim);padding:4px 0';
    el.textContent = text;
    area.appendChild(el);
    area.scrollTop = area.scrollHeight;
  }

  function updatePartialBubble(role, text) {
    const area = document.getElementById('convArea');
    if (!partialEls[role]) {
      if (role === 'model' && lastModelBubble) {
        // Gemini 中途触发 turnComplete 后继续说话：复用上一个气泡，追加新内容
        lastModelBubble.classList.add('partial');
        partialEls['model'] = { wrap: lastModelBubble.parentElement, bubble: lastModelBubble };
      } else {
        const wrap = document.createElement('div');
        const name = document.createElement('div');
        name.className = 'chat-name';
        name.textContent = role === 'user' ? t('me') : t('niannian');
        const bubble = document.createElement('div');
        bubble.className = `chat-bubble ${role} partial`;
        wrap.appendChild(name);
        wrap.appendChild(bubble);
        area.appendChild(wrap);
        partialEls[role] = { wrap, bubble };
      }
    }
    partialEls[role].bubble.textContent = lastModelTextPrefix + text;
    area.scrollTop = area.scrollHeight;
  }

  function finalizeBubble(role, text) {
    if (partialEls[role]) {
      partialEls[role].bubble.classList.remove('partial');
      partialEls[role].bubble.textContent = lastModelTextPrefix + text;
      if (role === 'model') {
        // 保存气泡引用，若 Gemini 继续说话可追加到同一气泡
        lastModelBubble = partialEls[role].bubble;
        lastModelTextPrefix = lastModelTextPrefix + text + ' ';
      }
      partialEls[role] = null;
    }
    // 无 partialEls 说明已被 type:'audio' 处理器提前完成，跳过避免重复气泡
  }

  function endConversation() {
    if (liveWs?.readyState === 1) {
      liveWs.send(JSON.stringify({ type: 'end' }));
    } else {
      resetConvUI();
    }
  }

  function resetConvUI() {
    convActive = false;
    modelSpeaking = false;
    userBargedIn = false;
    modelHasSpoken = false;
    vadFrameCount = 0;
    clearTimeout(connectTimer); connectTimer = null;
    clearTimeout(forceEndTimer); forceEndTimer = null; audioSendStart = null;
    clearTimeout(bargeInTimer); bargeInTimer = null;
    lastModelBubble = null; lastModelTextPrefix = '';
    convModelPCM = [];
    micStream?.getTracks().forEach(t => t.stop());
    workletNode?.disconnect();
    captureCtx?.close();
    playbackCtx?.close();
    liveWs?.close();
    micStream = workletNode = captureCtx = playbackCtx = masterGain = liveWs = null;
    nextPlayTime = 0;
    document.getElementById('recordBtn').classList.remove('recording');
    document.getElementById('recordBtn').disabled = false;
    document.getElementById('endConvBtn').classList.remove('active');
    document.getElementById('speakWave').classList.remove('active');
    document.getElementById('recordHint').innerHTML =
      t('recordHint') + '<br><span style="font-size:0.75rem;opacity:0.6">' + t('recordHintSub') + '</span>';
  }

  function finishConversation(transcript) {
    // 保存对话文字记录和念念语音到日记条目
    if (transcript?.length) {
      const id = Date.now();
      const timeStr = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
      const escHtml = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const turns = transcript.map(item => {
        const isUser = item.role === 'user';
        const role = escHtml(isUser ? t('me') : t('niannian'));
        return `<div class="conv-turn-${isUser ? 'user' : 'model'}">` +
          `<span class="conv-role">${role}</span>${escHtml(item.text)}</div>`;
      }).join('');
      const entryText = `🎙️ <div class="conv-entry">${turns}</div>`;
      entries.push({ id, date: getTodayStr(), time: timeStr, text: entryText, loading: false });
      saveEntries();
      if (convModelPCM.length > 0) {
        const wavBlob = encodeWAV(convModelPCM, 24000);
        saveAudio(id, wavBlob);
      }
      renderEntries();
      showToast(t('convRecorded'));
    }
    resetConvUI();
    document.getElementById('convArea').classList.remove('active');
  }

  // 将念念 PCM 数据编码为 WAV Blob（纯 JS，无需外部库）
  function encodeWAV(chunks, sampleRate) {
    const totalLen = chunks.reduce((n, c) => n + c.length, 0);
    const pcm = new Int16Array(totalLen);
    let offset = 0;
    for (const c of chunks) { pcm.set(c, offset); offset += c.length; }
    const dataLen = pcm.byteLength;
    const buf = new ArrayBuffer(44 + dataLen);
    const v = new DataView(buf);
    const s = (o, t) => { for (let i = 0; i < t.length; i++) v.setUint8(o+i, t.charCodeAt(i)); };
    s(0, 'RIFF'); v.setUint32(4, 36 + dataLen, true);
    s(8, 'WAVE'); s(12, 'fmt ');
    v.setUint32(16, 16, true); v.setUint16(20, 1, true);
    v.setUint16(22, 1, true); v.setUint32(24, sampleRate, true);
    v.setUint32(28, sampleRate * 2, true); v.setUint16(32, 2, true);
    v.setUint16(34, 16, true); s(36, 'data');
    v.setUint32(40, dataLen, true);
    new Int16Array(buf, 44).set(pcm);
    return new Blob([buf], { type: 'audio/wav' });
  }

  // 立即停止 agent 语音播放（用户打断时调用）
  function stopPlayback() {
    if (playbackCtx) {
      if (masterGain) masterGain.gain.setValueAtTime(0, playbackCtx.currentTime);
      playbackCtx.close().catch(() => {});
      playbackCtx = null;
      masterGain = null;
      nextPlayTime = 0;
    }
    document.getElementById('speakWave').classList.remove('active');
  }

  // PCM 音频播放（Int16 24kHz → AudioContext 排队播放）
  function playPCMChunk(b64, sampleRate) {
    if (!playbackCtx) {
      playbackCtx = new AudioContext({ sampleRate });
      masterGain = playbackCtx.createGain();
      masterGain.connect(playbackCtx.destination);
      nextPlayTime = 0;
    }
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    const samples = new Int16Array(bytes.buffer);
    const f32 = new Float32Array(samples.length);
    for (let i = 0; i < samples.length; i++) f32[i] = samples[i] / 32768;
    const buf = playbackCtx.createBuffer(1, f32.length, sampleRate);
    buf.getChannelData(0).set(f32);
    const src = playbackCtx.createBufferSource();
    src.buffer = buf;
    src.connect(masterGain);
    const startAt = Math.max(playbackCtx.currentTime, nextPlayTime);
    src.start(startAt);
    src.onended = () => src.disconnect();
    nextPlayTime = startAt + buf.duration;
  }

  async function startRecording() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      audioChunks = [];

      const mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
        ? 'audio/webm;codecs=opus'
        : MediaRecorder.isTypeSupported('audio/webm')
        ? 'audio/webm'
        : 'audio/mp4';

      mediaRecorder = new MediaRecorder(stream, { mimeType });
      mediaRecorder.ondataavailable = e => { if (e.data.size > 0) audioChunks.push(e.data); };
      mediaRecorder.onstop = () => {
        stream.getTracks().forEach(t => t.stop());
        processAudio(mimeType);
      };
      mediaRecorder.start(100);

      isRecording = true;
      secondsElapsed = 0;
      document.getElementById('recordBtn').classList.add('recording');
      document.getElementById('timer').classList.add('visible');
      document.getElementById('recordHint').textContent = t('recording');

      timerInterval = setInterval(() => {
        secondsElapsed++;
        const m = Math.floor(secondsElapsed / 60);
        const s = secondsElapsed % 60;
        document.getElementById('timer').textContent = `${m}:${s.toString().padStart(2,'0')}`;
      }, 1000);

    } catch(e) {
      showToast(t('micFail'));
    }
  }

  function stopRecording() {
    if (mediaRecorder) mediaRecorder.stop();
    isRecording = false;
    clearInterval(timerInterval);
    document.getElementById('recordBtn').classList.remove('recording');
    document.getElementById('timer').classList.remove('visible');
    document.getElementById('recordHint').innerHTML = t('transcribing');
  }

  async function processAudio(mimeType) {
    transcribing = true;
    document.getElementById('recordBtn').disabled = true;
    const blob = new Blob(audioChunks, { type: mimeType });

    const id = Date.now();
    const timeStr = new Date().toLocaleTimeString('zh-CN', { hour:'2-digit', minute:'2-digit' });
    entries.push({ id, date: getTodayStr(), time: timeStr, text: '', loading: true });
    renderEntries();

    try {
      const formData = new FormData();
      formData.append('audio', blob, 'recording.' + (mimeType.includes('mp4') ? 'm4a' : 'webm'));
      const res = await fetch('/api/transcribe', { method: 'POST', body: formData });
      const data = await res.json();
      if (data.text) {
        const entry = entries.find(e => e.id === id);
        if (entry) { entry.text = data.text; entry.loading = false; entry.hasAudio = true; }
        saveAudio(id, blob);
      } else {
        entries = entries.filter(e => e.id !== id);
        showToast(t('transcribeFail'));
      }
    } catch(e) {
      entries = entries.filter(e => e.id !== id);
      showToast(t('netFail'));
    }

    saveEntries();
    renderEntries();
    transcribing = false;
    document.getElementById('recordBtn').disabled = false;
    document.getElementById('recordHint').innerHTML = t('recordHintDone') + '<br><span style="font-size:0.75rem;opacity:0.6">' + t('recordHintDoneSub') + '</span>';
  }

  // Summary
  async function generateSummary() {
    const btn = document.getElementById('summaryBtn');
    const card = document.getElementById('summaryCard');
    const text = document.getElementById('summaryText');

    const todayEntries = entries.filter(e => e.date === getTodayStr() && !e.loading && e.text && !e.hidden);
    if (todayEntries.length === 0) return;

    btn.disabled = true;
    btn.innerHTML = t('summarizing');
    card.classList.remove('visible');

    try {
      const res = await fetch('/api/summarize', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entries: todayEntries, lang: currentLang })
      });
      const data = await res.json();
      if (data.summary) {
        const today = getTodayStr();
        titles[today] = data.title || '';
        localStorage.setItem('vd_titles', JSON.stringify(titles));
        summaries[today] = data.summary;
        localStorage.setItem('vd_summaries', JSON.stringify(summaries));
        document.getElementById('summaryTitle').textContent = data.title || '';
        text.textContent = data.summary;
        card.classList.add('visible');
        card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        showToast(t('genFail'));
      }
    } catch(e) {
      showToast(t('netFail'));
    }

    btn.disabled = false;
    btn.innerHTML = t('regen');
  }

  function copySummary() {
    const text = document.getElementById('summaryText').textContent;
    navigator.clipboard.writeText(text).then(() => showToast(t('copyDone')));
  }

  // Search
  function toggleSearch() {
    const bar = document.getElementById('searchBar');
    const isOpen = bar.style.display !== 'none';
    if (isOpen) {
      closeSearch();
    } else {
      bar.style.display = 'flex';
      document.getElementById('searchInput').focus();
    }
  }

  function closeSearch() {
    document.getElementById('searchBar').style.display = 'none';
    document.getElementById('searchResults').style.display = 'none';
    document.getElementById('searchInput').value = '';
  }

  function performSearch(query) {
    const results = document.getElementById('searchResults');
    if (!query.trim()) { results.style.display = 'none'; return; }
    const matched = entries.filter(e => !e.loading && e.text && !e.hidden && e.text.includes(query));
    if (matched.length === 0) {
      results.innerHTML = `<div style="color:var(--text-dim);padding:12px 0;font-size:0.88rem">${t('searchEmpty')}</div>`;
      results.style.display = '';
      return;
    }
    const byDate = {};
    for (const e of matched) {
      if (!byDate[e.date]) byDate[e.date] = [];
      byDate[e.date].push(e);
    }
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    results.innerHTML = Object.keys(byDate).sort().reverse().map(date => `
      <div style="margin-bottom:16px">
        <div class="summary-label" style="margin-bottom:8px">${date}</div>
        ${byDate[date].map(e => `
          <div class="entry-card" style="animation:none">
            <div class="entry-time">${e.time}</div>
            <div class="entry-text">${e.text.replace(new RegExp(escaped, 'g'), m => `<mark style="background:var(--warm-dim);color:var(--warm);border-radius:3px">${m}</mark>`)}</div>
          </div>`).join('')}
      </div>`).join('');
    results.innerHTML = `<div style="color:var(--text-dim);font-size:0.78rem;margin-bottom:12px">${t('searchFound')} ${matched.length} ${t('searchFoundSuffix')}</div>` + results.innerHTML;
    results.style.display = '';
  }

  function showToast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg;
    el.classList.add('show');
    setTimeout(() => el.classList.remove('show'), 2500);
  }

  function showUndoToast(msg, onUndo) {
    const el = document.getElementById('toast');
    el.innerHTML = '';
    const span = document.createElement('span');
    span.textContent = msg;
    el.appendChild(span);
    const btn = document.createElement('button');
    btn.textContent = t('undo');
    btn.style.cssText = 'background:none;border:none;color:var(--warm);font-weight:bold;cursor:pointer;margin-left:12px;font-size:inherit;text-decoration:underline;';
    btn.onclick = () => { onUndo(); el.classList.remove('show'); };
    el.appendChild(btn);
    el.classList.add('show');
    setTimeout(() => { el.classList.remove('show'); }, 5000);
  }

  // View switching
  function switchView(view) {
    document.getElementById('todayView').style.display = view === 'today' ? '' : 'none';
    document.getElementById('albumView').style.display = view === 'album' ? '' : 'none';
    document.getElementById('calendarView').style.display = view === 'calendar' ? '' : 'none';
    document.getElementById('tabToday').classList.toggle('active', view === 'today');
    document.getElementById('tabAlbum').classList.toggle('active', view === 'album');
    document.getElementById('tabCalendar').classList.toggle('active', view === 'calendar');
    if (view === 'calendar') renderCalendar();
    if (view === 'album') renderAlbum();
  }

  async function renderAlbum() {
    const grid = document.getElementById('albumGrid');
    grid.innerHTML = '';
    const all = await getAllIllus();
    if (!all.length) {
      grid.innerHTML = `<div class="album-empty" style="grid-column:1/-1">${t('albumEmpty')}</div>`;
      return;
    }
    all.sort((a, b) => b.dateStr.localeCompare(a.dateStr));
    const locale = currentLang === 'en' ? 'en-US' : 'zh-CN';
    for (const { dateStr, dataUrl } of all) {
      const summary = summaries[dateStr] || '';
      const title = titles[dateStr] || '';
      const dateLabel = (() => {
        try { return new Date(dateStr.replace(/\//g, '-') + 'T12:00:00').toLocaleDateString(locale, { month:'long', day:'numeric' }); }
        catch { return dateStr; }
      })();
      const summaryText = summary || (currentLang === 'en' ? 'No summary yet' : '暂无总结');
      const expandLabel = currentLang === 'en' ? 'Expand' : '展开全文';
      const card = document.createElement('div');
      card.className = 'album-card';
      card.innerHTML = `
        <div class="album-card-inner">
          <div class="album-card-front"><img src="${dataUrl}" alt="${dateStr}"></div>
          <div class="album-card-back">
            <div class="album-card-date">${dateLabel}</div>
            ${title ? `<div class="album-card-title">${title}</div>` : ''}
            <div class="album-card-summary clamped">${summaryText}</div>
            <button class="album-expand-btn">${expandLabel}</button>
          </div>
        </div>`;
      card.onclick = () => card.classList.toggle('flipped');
      const sumDiv = card.querySelector('.album-card-summary');
      const expandBtn = card.querySelector('.album-expand-btn');
      expandBtn.onclick = e => {
        e.stopPropagation();
        const expanding = sumDiv.classList.contains('clamped');
        sumDiv.classList.toggle('clamped', !expanding);
        expandBtn.textContent = expanding
          ? (currentLang === 'en' ? 'Collapse' : '收起')
          : (currentLang === 'en' ? 'Expand' : '展开全文');
      };
      grid.appendChild(card);
    }
  }

  // Calendar
  function changeMonth(delta) {
    calMonth += delta;
    if (calMonth > 11) { calMonth = 0; calYear++; }
    if (calMonth < 0) { calMonth = 11; calYear--; }
    calSelected = null;
    document.getElementById('calDayPanel').style.display = 'none';
    renderCalendar();
  }

  function renderCalendar() {
    const today = getTodayStr();
    const datesWithEntries = new Set(entries.filter(e => !e.loading).map(e => e.date));

    const calLocale = currentLang === 'en' ? 'en-US' : 'zh-CN';
    document.getElementById('calTitle').textContent =
      new Date(calYear, calMonth, 1).toLocaleDateString(calLocale, { year:'numeric', month:'long' });

    const grid = document.getElementById('calGrid');
    grid.innerHTML = '';

    const firstDay = new Date(calYear, calMonth, 1).getDay();
    const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
    const daysInPrev = new Date(calYear, calMonth, 0).getDate();

    // Previous month padding
    for (let i = firstDay - 1; i >= 0; i--) {
      const d = document.createElement('div');
      d.className = 'cal-day other-month';
      d.textContent = daysInPrev - i;
      grid.appendChild(d);
    }

    // Current month days
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = new Date(calYear, calMonth, day)
        .toLocaleDateString(currentLang === 'en' ? 'en-CA' : 'zh-CN', { year:'numeric', month:'2-digit', day:'2-digit' });
      const d = document.createElement('div');
      d.className = 'cal-day';
      d.textContent = day;
      if (dateStr === today) d.classList.add('today');
      if (datesWithEntries.has(dateStr)) d.classList.add('has-entry');
      if (dateStr === calSelected) d.classList.add('selected');
      d.onclick = () => selectDay(dateStr, d);
      grid.appendChild(d);
    }

    // Next month padding
    const totalCells = firstDay + daysInMonth;
    const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
    for (let i = 1; i <= remaining; i++) {
      const d = document.createElement('div');
      d.className = 'cal-day other-month';
      d.textContent = i;
      grid.appendChild(d);
    }
  }

  async function selectDay(dateStr, el) {
    calSelected = dateStr;
    document.querySelectorAll('.cal-day.selected').forEach(d => d.classList.remove('selected'));
    el.classList.add('selected');

    const dayEntries = entries.filter(e => e.date === dateStr && !e.loading);
    const panel = document.getElementById('calDayPanel');
    const title = document.getElementById('calDayTitle');
    const list = document.getElementById('calDayEntries');

    title.textContent = dateStr;
    list.innerHTML = '';

    if (dayEntries.length === 0) {
      list.innerHTML = `<div style="color:var(--text-dim);font-size:0.85rem;padding:8px 0">${t('noRecord')}</div>`;
    } else {
      dayEntries.forEach(entry => {
        const card = document.createElement('div');
        card.className = 'entry-card';
        card.style.animation = 'none';
        card.innerHTML = `
          <div class="entry-time">${entry.time}${entry.hasAudio ? ` <button class="play-btn" data-id="${entry.id}" onclick="playAudio(${entry.id})" title="${t('playHint')}">▶</button>` : ''}</div>
          <div class="entry-text">${entry.text}</div>
        `;
        list.appendChild(card);
      });
    }

    // Summary section
    const summaryDiv = document.createElement('div');
    summaryDiv.style.marginTop = '16px';
    const existingSummary = summaries[dateStr];
    if (existingSummary) {
      summaryDiv.innerHTML = `
        <div class="summary-label" style="margin-bottom:8px">${t('daySum')}</div>
        ${titles[dateStr] ? `<div style="font-size:1rem;font-weight:600;color:var(--warm);margin-bottom:8px">${titles[dateStr]}</div>` : ''}
        <div style="font-size:0.85rem;line-height:1.8;color:var(--text);white-space:pre-wrap">${existingSummary}</div>
        <div style="margin-top:10px;display:flex;gap:8px;flex-wrap:wrap">
          <button class="copy-btn" style="margin-top:0" onclick="generateSummaryForDate('${dateStr}')">${t('regenSum')}</button>
          <button class="copy-btn" style="margin-top:0" onclick="generateIllus('${dateStr}')">${t('illusBtn')}</button>
        </div>`;
    } else if (dayEntries.length > 0) {
      summaryDiv.innerHTML = `
        <button class="copy-btn" style="margin-top:0" onclick="generateSummaryForDate('${dateStr}')">${t('genSum')}</button>`;
    }
    list.appendChild(summaryDiv);

    // Illustration (load from IndexedDB if exists)
    const illusData = await getIllus(dateStr);
    if (illusData) {
      const imgDiv = document.createElement('div');
      imgDiv.style.marginTop = '12px';
      imgDiv.innerHTML = `<img src="${illusData}" style="width:100%;border-radius:12px;display:block">`;
      list.appendChild(imgDiv);
    }

    panel.style.display = '';
    panel.scrollIntoView({ behavior:'smooth', block:'nearest' });
  }

  // Generate summary for any date (used from calendar view)
  async function generateSummaryForDate(dateStr) {
    const dateEntries = entries.filter(e => e.date === dateStr && !e.loading && e.text && !e.hidden);
    if (!dateEntries.length) { showToast(t('noRecordForSum')); return; }
    showToast(t('sumGenerating'));
    try {
      const res = await fetch('/api/summarize', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ entries: dateEntries, lang: currentLang })
      });
      const data = await res.json();
      if (data.summary) {
        titles[dateStr] = data.title || '';
        localStorage.setItem('vd_titles', JSON.stringify(titles));
        summaries[dateStr] = data.summary;
        localStorage.setItem('vd_summaries', JSON.stringify(summaries));
        const sel = document.querySelector('.cal-day.selected');
        if (sel && calSelected === dateStr) selectDay(dateStr, sel);
        if (dateStr === getTodayStr()) {
          document.getElementById('summaryTitle').textContent = data.title || '';
          document.getElementById('summaryText').textContent = data.summary;
          document.getElementById('summaryCard').classList.add('visible');
        }
      } else { showToast(t('genFail')); }
    } catch(e) { showToast(t('netFail')); }
  }

  // Generate illustration for any date
  async function generateIllus(dateStr) {
    dateStr = dateStr || getTodayStr();
    const dateEntries = entries.filter(e => e.date === dateStr && !e.loading && e.text && !e.hidden);
    const summary = summaries[dateStr] || '';
    if (!dateEntries.length && !summary) { showToast(t('illusNeedContent')); return; }
    showToast(t('illusGeneratingLong'));
    try {
      const res = await fetch('/api/illustrate', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ entries: dateEntries, summary })
      });
      const data = await res.json();
      if (data.imageData) {
        await saveIllus(dateStr, data.imageData);
        if (dateStr === getTodayStr()) {
          const area = document.getElementById('illustrationArea');
          if (area) area.innerHTML = `<img src="${data.imageData}" style="width:100%;border-radius:12px;margin-top:4px;display:block">`;
        }
        const sel = document.querySelector('.cal-day.selected');
        if (sel && calSelected === dateStr) selectDay(dateStr, sel);
        showToast(t('illusGenerated'));
      } else {
        showToast(t('illusFail') + '：' + (data.error || '未知错误'));
      }
    } catch(e) { showToast(t('illusFail2')); }
  }

  // Word export
  async function exportToWord() {
    const validEntries = entries.filter(e => !e.loading && e.text && !e.hidden);
    if (validEntries.length === 0) { showToast(t('noExport')); return; }
    showToast(t('exporting'));
    // 收集涉及的日期，批量读取插图
    const dates = [...new Set(validEntries.map(e => e.date))];
    const illustrations = {};
    for (const d of dates) {
      const img = await getIllus(d);
      if (img) illustrations[d] = img;
    }
    const exportSummaries = Object.fromEntries(dates.filter(d => summaries[d]).map(d => [d, summaries[d]]));
    const exportTitles = Object.fromEntries(dates.filter(d => titles[d]).map(d => [d, titles[d]]));
    try {
      const res = await fetch('/api/export', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entries: validEntries, summaries: exportSummaries, titles: exportTitles, illustrations })
      });
      const blob = await res.blob();
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `碎碎念_${getTodayStr()}.docx`;
      a.click();
      URL.revokeObjectURL(a.href);
    } catch(e) {
      showToast(t('exportFail'));
    }
  }

  // Init
  const _now = new Date();
  calYear = _now.getFullYear();
  calMonth = _now.getMonth();
  setTheme(localStorage.getItem('vd_theme') || 'auto');
  renderEntries();
  // Restore today's summary and title if exists
  const todaySummary = summaries[getTodayStr()];
  if (todaySummary) {
    document.getElementById('summaryTitle').textContent = titles[getTodayStr()] || '';
    document.getElementById('summaryText').textContent = todaySummary;
    document.getElementById('summaryCard').classList.add('visible');
    document.getElementById('summaryBtn').innerHTML = t('regen');
  }
  // Restore today's illustration if exists
  getIllus(getTodayStr()).then(dataUrl => {
    if (dataUrl) {
      const area = document.getElementById('illustrationArea');
      if (area) area.innerHTML = `<img src="${dataUrl}" style="width:100%;border-radius:12px;margin-top:4px;display:block">`;
    }
  });
</script>
</body>
</html>
