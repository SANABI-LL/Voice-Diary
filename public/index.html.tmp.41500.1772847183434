<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>碎碎念 · 语音日记</title>
<link href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="manifest" href="/manifest.json">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="碎碎念">
<link rel="apple-touch-icon" href="/icon.png">
<meta name="theme-color" content="#13100e">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #13100e;
    --bg2: #1c1814;
    --bg3: #252018;
    --warm: #e8a857;
    --warm2: #c47f2e;
    --warm-dim: rgba(232,168,87,0.12);
    --warm-glow: rgba(232,168,87,0.06);
    --text: #e8ddd0;
    --text-dim: #9a8f82;
    --red: #d4604a;
    --border: rgba(232,168,87,0.15);
  }

  [data-theme="light"] {
    --bg: #faf8f4;
    --bg2: #f2ede4;
    --bg3: #e8e0d2;
    --warm: #b5740a;
    --warm2: #8a5500;
    --warm-dim: rgba(181,116,10,0.1);
    --warm-glow: rgba(181,116,10,0.05);
    --text: #2a1f0f;
    --text-dim: #7a6e5e;
    --red: #c0392b;
    --border: rgba(120,90,40,0.18);
  }

  @media (prefers-color-scheme: light) {
    [data-theme="auto"] {
      --bg: #faf8f4;
      --bg2: #f2ede4;
      --bg3: #e8e0d2;
      --warm: #b5740a;
      --warm2: #8a5500;
      --warm-dim: rgba(181,116,10,0.1);
      --warm-glow: rgba(181,116,10,0.05);
      --text: #2a1f0f;
      --text-dim: #7a6e5e;
      --red: #c0392b;
      --border: rgba(120,90,40,0.18);
    }
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Noto Serif SC', serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    background-image:
      radial-gradient(ellipse 60% 40% at 50% -10%, rgba(232,168,87,0.08) 0%, transparent 70%);
  }

  .main {
    width: 100%;
    max-width: 500px;
    padding: 0 16px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Record button */
  .record-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 32px 20px;
    background: var(--bg2);
    border-radius: 24px;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .record-area::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(232,168,87,0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  .record-btn {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    border: 2px solid var(--warm);
    background: var(--warm-dim);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }

  .record-btn:hover { background: rgba(232,168,87,0.2); transform: scale(1.05); }
  .record-btn:active { transform: scale(0.95); }

  .record-btn.recording {
    border-color: var(--red);
    background: rgba(212,96,74,0.15);
    animation: pulse 1.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(212,96,74,0.4); }
    50% { box-shadow: 0 0 0 16px rgba(212,96,74,0); }
  }

  .mic-icon {
    width: 32px;
    height: 32px;
    fill: var(--warm);
    transition: fill 0.2s;
  }
  .record-btn.recording .mic-icon { fill: var(--red); }

  .record-hint {
    font-size: 0.82rem;
    color: var(--text-dim);
    text-align: center;
    line-height: 1.6;
    min-height: 40px;
    display: flex;
    align-items: center;
  }

  .timer {
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.4rem;
    color: var(--red);
    min-width: 60px;
    text-align: center;
    display: none;
  }
  .timer.visible { display: block; }

  /* Entries list */
  .section-title {
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    color: var(--text-dim);
    text-transform: uppercase;
    padding: 0 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .entries-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .entry-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 14px 16px;
    position: relative;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .entry-time {
    font-size: 0.7rem;
    color: var(--warm2);
    letter-spacing: 0.1em;
    margin-bottom: 6px;
  }

  .entry-text {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text);
  }

  .entry-text.loading {
    color: var(--text-dim);
    font-style: italic;
  }

  /* 对话记录条目（念念 / 我 分块显示） */
  .conv-entry { display:flex; flex-direction:column; gap:8px; margin-top:4px; }
  .conv-turn-model { background:rgba(232,168,87,0.08); border-left:3px solid var(--warm);
    padding:7px 11px; border-radius:0 8px 8px 0; }
  .conv-turn-user { background:rgba(255,255,255,0.04); border-left:3px solid rgba(255,255,255,0.18);
    padding:7px 11px; border-radius:0 8px 8px 0; }
  .conv-role { font-size:0.68rem; font-weight:600; opacity:0.5; display:block;
    margin-bottom:3px; letter-spacing:0.05em; }

  /* ===== Album 相册 ===== */
  .album-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; padding:12px 16px; }
  .album-card { position:relative; aspect-ratio:1; cursor:pointer; }
  .album-card-inner {
    width:100%; height:100%; position:relative;
    transform-style:preserve-3d; transition:transform 0.5s cubic-bezier(0.4,0,0.2,1); }
  .album-card.flipped .album-card-inner { transform:rotateY(180deg); }
  .album-card-front, .album-card-back {
    position:absolute; inset:0; border-radius:16px; overflow:hidden;
    backface-visibility:hidden; -webkit-backface-visibility:hidden; }
  .album-card-front img { width:100%; height:100%; object-fit:cover; display:block; }
  .album-card-back {
    transform:rotateY(180deg);
    background:var(--bg2); border:1px solid rgba(232,168,87,0.3);
    padding:14px; display:flex; flex-direction:column; gap:6px; overflow:hidden; }
  .album-card-date { font-size:0.68rem; color:var(--warm); letter-spacing:0.1em; flex-shrink:0; }
  .album-card-title { font-size:0.82rem; font-weight:600; color:var(--text); flex-shrink:0; }
  .album-card-summary {
    font-size:0.72rem; line-height:1.6; color:var(--text-dim); flex:1; overflow:hidden; }
  .album-card-summary.clamped {
    display:-webkit-box; -webkit-line-clamp:5; -webkit-box-orient:vertical; overflow:hidden; }
  .album-expand-btn {
    flex-shrink:0; margin-top:4px; padding:2px 0; background:none; border:none; cursor:pointer;
    font-size:0.68rem; color:var(--warm); letter-spacing:0.03em; text-align:left; }
  .album-empty { text-align:center; padding:60px 20px; color:var(--text-dim); font-size:0.88rem; }
  /* Album detail overlay */
  .album-detail-overlay {
    position:fixed; inset:0; z-index:300; background:rgba(0,0,0,0.6);
    display:flex; align-items:flex-end; backdrop-filter:blur(4px); }
  .album-detail-sheet {
    width:100%; max-height:80vh; background:var(--bg2); border-radius:20px 20px 0 0;
    padding:24px 20px 48px; overflow-y:auto; display:flex; flex-direction:column; gap:8px; }
  .album-detail-img { width:100%; border-radius:12px; display:block; margin-bottom:4px; }
  .album-detail-date { font-size:0.72rem; color:var(--warm); letter-spacing:0.1em; }
  .album-detail-title { font-size:1rem; font-weight:700; color:var(--text); }
  .album-detail-text { font-size:0.88rem; line-height:1.9; color:var(--text-dim); white-space:pre-wrap; margin-top:4px; }
  .album-detail-translating { font-size:0.78rem; color:var(--warm); opacity:0.7; margin-top:4px; }
  .album-detail-close {
    margin-top:16px; padding:10px; background:rgba(255,255,255,0.07); border:none;
    border-radius:12px; color:var(--text-dim); font-size:0.88rem; cursor:pointer; width:100%; }

  .entry-delete {
    position: absolute;
    top: 10px;
    right: 12px;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-size: 1rem;
    padding: 2px 6px;
    border-radius: 8px;
    transition: all 0.15s;
    line-height: 1;
  }
  .entry-delete:hover { color: var(--red); background: rgba(212,96,74,0.1); }

  .empty-state {
    text-align: center;
    padding: 30px 20px;
    color: var(--text-dim);
    font-size: 0.85rem;
    line-height: 1.8;
    background: var(--bg2);
    border: 1px dashed var(--border);
    border-radius: 16px;
  }

  /* Summary */
  .summary-btn {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, var(--warm2), var(--warm));
    border: none;
    border-radius: 16px;
    color: var(--bg);
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }
  .summary-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .summary-btn:active { transform: translateY(0); }
  .summary-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .summary-card {
    background: var(--bg2);
    border: 1px solid rgba(232,168,87,0.3);
    border-radius: 20px;
    padding: 20px;
    display: none;
    animation: slideIn 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .summary-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--warm), transparent);
  }

  .summary-card.visible { display: block; }

  .summary-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: var(--warm);
    margin-bottom: 12px;
  }

  .summary-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--warm);
    margin-bottom: 10px;
  }

  .summary-text {
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--text);
    white-space: pre-wrap;
  }

  .copy-btn {
    margin-top: 14px;
    padding: 6px 16px;
    background: var(--warm-dim);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--warm);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'Noto Serif SC', serif;
  }
  .copy-btn:hover { background: rgba(232,168,87,0.2); }

  .spinner {
    display: inline-block;
    width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .toast {
    position: fixed;
    bottom: calc(49px + env(safe-area-inset-bottom, 0) + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 10px 20px;
    font-size: 0.82rem;
    color: var(--text);
    transition: transform 0.3s ease;
    z-index: 150;
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  #todayView { width: 100%; display: flex; flex-direction: column; align-items: center; }

  /* Calendar */
  .cal-nav { display:flex; justify-content:space-between; align-items:center; padding:4px 0 16px; }
  .cal-nav button { background:none; border:1px solid var(--border); color:var(--text-dim);
                    border-radius:12px; padding:6px 14px; cursor:pointer; font-size:1.1rem; }
  .cal-nav button:hover { color:var(--warm); border-color:var(--warm); }
  .cal-title { font-size:0.95rem; color:var(--text); letter-spacing:0.1em; }
  .cal-weekdays { display:grid; grid-template-columns:repeat(7,1fr); text-align:center;
                  font-size:0.68rem; color:var(--text-dim); margin-bottom:6px; }
  .cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; }
  .cal-day { aspect-ratio:1; display:flex; flex-direction:column; align-items:center;
             justify-content:center; border-radius:8px; cursor:pointer; font-size:0.82rem;
             color:var(--text); transition:background 0.15s; }
  .cal-day:hover { background:var(--warm-dim); }
  .cal-day.has-entry { color:var(--warm); font-weight:500; }
  .cal-day.has-entry::after { content:'·'; display:block; font-size:1.2rem; line-height:0.4; color:var(--warm); }
  .cal-day.today { background:var(--warm-dim); }
  .cal-day.selected { background:var(--warm) !important; color:#13100e !important; }
  .cal-day.other-month { opacity:0.3; }
  .cal-day-panel { background:var(--bg2); border:1px solid var(--border); border-radius:20px;
                   padding:16px; margin-top:16px; animation:slideIn 0.3s ease; }

  /* Play button */
  .play-btn { background:none; border:none; color:var(--text-dim); cursor:pointer;
              font-size:0.78rem; padding:2px 8px; border-radius:8px; transition:all 0.15s; }
  .play-btn:hover { color:var(--warm); background:var(--warm-dim); }

  /* Hide button */
  .entry-hide { position:absolute; top:10px; right:36px; background:none; border:none;
                cursor:pointer; font-size:0.78rem; padding:2px 6px; border-radius:6px;
                color:var(--text-dim); transition:all 0.15s; }
  .entry-hide:hover { color:var(--text); background:var(--warm-dim); }
  .entry-hidden { color:var(--text-dim) !important; font-style:italic; letter-spacing:0.1em; }

  /* Export button */
  .export-btn { width:100%; margin-top:8px; padding:13px; background:var(--bg3);
                border:1px solid var(--border); color:var(--text-dim); border-radius:16px;
                cursor:pointer; font-family:'Noto Serif SC',serif; font-size:0.85rem; transition:all 0.2s; }
  .export-btn:hover { border-color:var(--warm); color:var(--warm); }

  /* Search */
  .search-bar { display:flex; align-items:center; gap:8px; width:100%; max-width:500px;
                padding:0 16px 12px; box-sizing:border-box; }
  .search-bar input { flex:1; background:var(--bg2); border:1px solid var(--border);
                      border-radius:20px; padding:8px 16px; color:var(--text);
                      font-size:0.9rem; font-family:'Noto Serif SC',serif; outline:none;
                      transition:border-color 0.2s; }
  .search-bar input:focus { border-color:var(--warm); }
  .search-bar input::placeholder { color:var(--text-dim); }
  .search-close { background:none; border:none; color:var(--text-dim); font-size:1rem;
                  cursor:pointer; padding:4px 8px; border-radius:10px; transition:all 0.2s; }
  .search-close:hover { color:var(--warm); }
  /* ===== Gemini Live 对话区 ===== */
  .conversation-area {
    display: none; flex-direction: column; gap: 10px;
    max-height: 44vh; overflow-y: auto; width: 100%; padding: 2px 0 4px;
    scroll-behavior: smooth;
  }
  .conversation-area.active { display: flex; }
  .chat-bubble {
    max-width: 82%; padding: 10px 14px; border-radius: 18px;
    font-size: 0.87rem; line-height: 1.65; animation: slideIn 0.2s ease;
    word-break: break-all;
  }
  .chat-bubble.user {
    align-self: flex-end; background: var(--warm-dim);
    border: 1px solid rgba(232,168,87,0.25); color: var(--text);
    border-bottom-right-radius: 4px;
  }
  .chat-bubble.model {
    align-self: flex-start; background: var(--bg2);
    border: 1px solid var(--border); color: var(--text);
    border-bottom-left-radius: 4px;
  }
  .chat-bubble.partial { opacity: 0.55; font-style: italic; }
  .chat-name {
    font-size: 0.65rem; color: var(--text-dim); margin-bottom: 3px;
    letter-spacing: 0.05em;
  }
  /* 念念说话时的波形动画 */
  .speaking-wave {
    display: none; align-items: center; gap: 3px; height: 22px;
    padding-left: 4px;
  }
  .speaking-wave.active { display: flex; }
  .speaking-wave span {
    width: 3px; min-height: 4px; background: var(--warm); border-radius: 3px;
    animation: wave 0.9s ease-in-out infinite;
  }
  .speaking-wave span:nth-child(2) { animation-delay: 0.12s; }
  .speaking-wave span:nth-child(3) { animation-delay: 0.24s; }
  .speaking-wave span:nth-child(4) { animation-delay: 0.36s; }
  .speaking-wave span:nth-child(5) { animation-delay: 0.48s; }
  @keyframes wave {
    0%, 100% { height: 4px; } 50% { height: 18px; }
  }
  /* 结束对话按钮 */
  .end-conv-btn {
    display: none; width: 100%; padding: 13px;
    background: rgba(212,96,74,0.1); border: 1px solid rgba(212,96,74,0.3);
    border-radius: 16px; color: var(--red); font-size: 0.88rem;
    cursor: pointer; transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
    font-family: -apple-system, 'PingFang SC', sans-serif;
  }
  .end-conv-btn.active { display: block; }
  .end-conv-btn:active { background: rgba(212,96,74,0.2); }

  /* ===== iOS Navigation Bar ===== */
  .ios-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding-top: env(safe-area-inset-top, 0);
    background: rgba(19,16,14,0.88);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-bottom: 0.5px solid var(--border);
  }
  [data-theme="light"] .ios-nav { background: rgba(250,248,244,0.88); }
  .ios-nav-inner {
    height: 44px; display: flex; align-items: center;
    justify-content: space-between; padding: 0 4px;
    position: relative;
  }
  .ios-nav-center {
    position: absolute; left: 50%; transform: translateX(-50%);
    text-align: center; pointer-events: none;
  }
  .ios-nav-logo {
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.3rem; color: var(--warm); line-height: 1.1;
    text-shadow: 0 0 20px rgba(232,168,87,0.3);
  }
  .ios-nav-date {
    font-size: 0.58rem; color: var(--text-dim); letter-spacing: 0.15em;
  }
  .ios-nav-btn {
    background: none; border: none; color: var(--text-dim);
    padding: 0; border-radius: 50%; cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    min-width: 44px; min-height: 44px;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .ios-nav-btn svg { width: 22px; height: 22px; fill: var(--text-dim); transition: fill 0.15s; }
  .ios-nav-btn:active { background: var(--warm-dim); }
  .ios-nav-btn:active svg { fill: var(--warm); }
  .ios-nav-right { display: flex; gap: 0; }
  .ios-nav-left { display: flex; gap: 0; }

  /* Theme Popover */
  .theme-popover {
    display: none; position: fixed;
    top: calc(env(safe-area-inset-top, 0) + 50px); right: 8px;
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.45);
    z-index: 200; min-width: 130px;
  }
  .theme-popover.open { display: block; animation: popIn 0.18s ease; }
  @keyframes popIn {
    from { opacity: 0; transform: scale(0.9) translateY(-8px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .theme-item {
    display: flex; align-items: center; gap: 10px;
    padding: 13px 16px; cursor: pointer;
    font-size: 0.88rem; color: var(--text);
    border-bottom: 0.5px solid var(--border);
    -webkit-tap-highlight-color: transparent;
    transition: background 0.1s;
  }
  .theme-item:last-child { border-bottom: none; }
  .theme-item:active { background: var(--warm-dim); }
  .theme-item.active { color: var(--warm); font-weight: 500; }
  .theme-overlay {
    display: none; position: fixed; inset: 0; z-index: 199;
  }
  .theme-overlay.open { display: block; }

  /* ===== iOS Bottom Tab Bar ===== */
  .ios-tab-bar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
    padding-bottom: env(safe-area-inset-bottom, 0);
    background: rgba(19,16,14,0.88);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border-top: 0.5px solid var(--border);
    display: flex;
  }
  [data-theme="light"] .ios-tab-bar { background: rgba(250,248,244,0.88); }
  .ios-tab {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 4px;
    height: 49px; border: none; background: transparent; cursor: pointer;
