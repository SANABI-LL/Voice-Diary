  let bargeInTimer = null;     // 防止 userBargedIn 永久卡住的安全超时
  let convModelPCM = [];       // 收集本次对话念念的全部 PCM 数据（Int16Array[]）

  // WebSocket URL 自动适配（本地 ws:// 生产 wss://）
  const WS_URL = (() => {
    const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
    return `${proto}//${location.host}/live`;
  })();

  // PCM 采集 AudioWorklet 代码（Blob URL 注入，避免单独文件）
  const WORKLET_CODE = `
class PCMProcessor extends AudioWorkletProcessor {
  process(inputs) {
    const ch = inputs[0]?.[0];
    if (ch) {
      const i16 = new Int16Array(ch.length);
      for (let i = 0; i < ch.length; i++)
        i16[i] = Math.max(-32768, Math.min(32767, ch[i] * 32768));
      this.port.postMessage(i16.buffer, [i16.buffer]);
    }
    return true;
  }
}
registerProcessor('pcm-proc', PCMProcessor);
`;

  // IndexedDB for audio + illustration storage
  function openDB() {
    return new Promise((resolve, reject) => {
      const req = indexedDB.open('voice-diary-audio', 2);
      req.onupgradeneeded = e => {
        const db = e.target.result;
        if (!db.objectStoreNames.contains('audio')) db.createObjectStore('audio');
        if (!db.objectStoreNames.contains('illus')) db.createObjectStore('illus');
      };
      req.onsuccess = e => resolve(e.target.result);
      req.onerror = reject;
    });
  }
  async function saveAudio(id, blob) {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction('audio', 'readwrite');
      tx.objectStore('audio').put(blob, id);
      tx.oncomplete = resolve; tx.onerror = reject;
    });
  }
  async function getAudio(id) {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction('audio', 'readonly');
      const req = tx.objectStore('audio').get(id);
      req.onsuccess = e => resolve(e.target.result); req.onerror = reject;
    });
  }
  async function deleteAudio(id) {
    const db = await openDB();
    const tx = db.transaction('audio', 'readwrite');
    tx.objectStore('audio').delete(id);
  }
  async function saveIllus(dateStr, dataUrl) {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction('illus', 'readwrite');
      tx.objectStore('illus').put(dataUrl, dateStr);
      tx.oncomplete = resolve; tx.onerror = reject;
    });
  }
  async function getIllus(dateStr) {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction('illus', 'readonly');
      const req = tx.objectStore('illus').get(dateStr);
      req.onsuccess = e => resolve(e.target.result); req.onerror = reject;
    });
  }
  async function getAllIllus() {
    const db = await openDB();
    return new Promise((resolve, reject) => {
      const tx = db.transaction('illus', 'readonly');
      const result = [];
      tx.objectStore('illus').openCursor().onsuccess = e => {
        const c = e.target.result;
        if (c) { result.push({ dateStr: c.key, dataUrl: c.value }); c.continue(); }
        else resolve(result);
      };
      tx.onerror = reject;
    });
  }

  function setPlayBtn(id, playing) {
    document.querySelectorAll(`.play-btn[data-id="${id}"]`).forEach(btn => {
      btn.textContent = playing ? '⏸' : '▶';
      btn.title = playing ? '暂停' : '播放录音';
    });
  }

  async function playAudio(id) {
    // If this entry is playing, pause it
    if (currentPlayId === id && currentAudio) {
      currentAudio.pause();
      currentAudio = null;
      currentPlayId = null;
      setPlayBtn(id, false);
      return;
    }
    // Stop any other playing audio
    if (currentAudio) {
      currentAudio.pause();
      URL.revokeObjectURL(currentAudio.src);
      setPlayBtn(currentPlayId, false);
      currentAudio = null;
      currentPlayId = null;
    }
    const blob = await getAudio(id);
    if (!blob) { showToast(t('noAudio')); return; }
    const url = URL.createObjectURL(blob);
    const audio = new Audio(url);
    audio.onended = () => {
      URL.revokeObjectURL(url);
      setPlayBtn(id, false);
      currentAudio = null;
      currentPlayId = null;
    };
    audio.play();
    currentAudio = audio;
    currentPlayId = id;
    setPlayBtn(id, true);
  }

