  function deleteEntry(id) {
    const entry = entries.find(e => e.id === id);
    if (!entry) return;
    entries = entries.filter(e => e.id !== id);
    saveEntries();
    renderEntries();

    let undone = false;
    const audioTimer = entry.hasAudio ? setTimeout(() => { if (!undone) deleteAudio(id); }, 5000) : null;

    showUndoToast(t('deleted'), () => {
      undone = true;
      clearTimeout(audioTimer);
      entries.push(entry);
      entries.sort((a, b) => a.id - b.id);
      saveEntries();
      renderEntries();
    });
